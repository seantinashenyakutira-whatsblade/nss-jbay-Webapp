<section class="auth-page" data-animate="fade-in">
  <div class="auth-card">
    <h1 class="auth-card__title" style="font-size:2rem;text-align:center;">Reset Password</h1>
    <p class="auth-card__subtitle" style="text-align:center;color:var(--clr-text-muted);margin-bottom:32px;">Enter your email and we'll send you a reset link</p>

    <form action="/auth/forgot-password" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label form-label--required" for="email">Email</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required autocomplete="email">
      </div>
      <button type="submit" class="btn btn--primary btn--block btn--lg">Send Reset Link</button>
    </form>

    <div style="text-align:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--clr-border);">
      <p style="font-size:0.875rem;color:var(--clr-text-muted);">Remember your password? <a href="/auth/login" style="color:var(--clr-primary);">Log in</a></p>
    </div>
  </div>
</section>
