<section class="auth-page" data-animate="fade-in">
  <div class="auth-card">
    <div class="auth-tabs" role="tablist">
      <button type="button" class="auth-tab<%= typeof registerActive !== 'undefined' && registerActive ? '' : ' active' %>" data-tab="login" role="tab" aria-selected="<%= typeof registerActive !== 'undefined' && registerActive ? 'false' : 'true' %>">Log In</button>
      <button type="button" class="auth-tab<%= typeof registerActive !== 'undefined' && registerActive ? ' active' : '' %>" data-tab="register" role="tab" aria-selected="<%= typeof registerActive !== 'undefined' && registerActive ? 'true' : 'false' %>">Create Account</button>
    </div>

    <div class="auth-panel active" id="tab-login" role="tabpanel">
      <form action="/auth/login" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length) { %>
          <% error_msg.forEach(function(msg) { %>
            <div class="form-feedback form-feedback--error" role="alert"><%= msg %></div>
          <% }); %>
        <% } %>

        <div class="form-group">
          <label class="form-label form-label--required" for="loginEmail">Email</label>
          <input type="email" id="loginEmail" name="email" class="form-input" placeholder="your@email.com" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label form-label--required" for="loginPassword">Password</label>
          <input type="password" id="loginPassword" name="password" class="form-input" placeholder="Enter your password" required autocomplete="current-password">
        </div>
        <div class="form-group text-right">
          <a href="/auth/forgot-password" class="text-sm text-muted">Forgot password?</a>
        </div>
        <button type="submit" class="btn btn--primary btn--block btn--lg">Log In</button>
      </form>
    </div>

    <div class="auth-panel" id="tab-register" role="tabpanel">
      <form action="/auth/register" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (typeof registerActive !== 'undefined' && registerActive && typeof error_msg !== 'undefined' && error_msg && error_msg.length) { %>
          <% error_msg.forEach(function(msg) { %>
            <div class="form-feedback form-feedback--error" role="alert"><%= msg %></div>
          <% }); %>
        <% } %>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label form-label--required" for="regFirstName">First Name</label>
            <input type="text" id="regFirstName" name="firstName" class="form-input" placeholder="John" required>
          </div>
          <div class="form-group">
            <label class="form-label form-label--required" for="regLastName">Last Name</label>
            <input type="text" id="regLastName" name="lastName" class="form-input" placeholder="Doe" required>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label form-label--required" for="regEmail">Email</label>
          <input type="email" id="regEmail" name="email" class="form-input" placeholder="your@email.com" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="regPhone">Phone (optional)</label>
          <input type="tel" id="regPhone" name="phone" class="form-input" placeholder="063 546 1740">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label form-label--required" for="regPassword">Password</label>
            <input type="password" id="regPassword" name="password" class="form-input" placeholder="Min. 8 characters" required minlength="8" autocomplete="new-password">
          </div>
          <div class="form-group">
            <label class="form-label form-label--required" for="regConfirm">Confirm Password</label>
            <input type="password" id="regConfirm" name="confirmPassword" class="form-input" placeholder="Repeat password" required minlength="8" autocomplete="new-password">
          </div>
        </div>
        <button type="submit" class="btn btn--primary btn--block btn--lg">Create Account</button>
      </form>
    </div>
  </div>
</section>
