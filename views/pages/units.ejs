<section class="page" data-animate="fade-in">
  <div class="container">
    <div class="page__header flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="page__title">BROWSE &amp; BOOK</h1>
        <p class="page__subtitle"><%= typeof units !== 'undefined' ? units.length : 0 %> unit<%= typeof units !== 'undefined' && units.length !== 1 ? 's' : '' %> available</p>
      </div>
      <div class="units-search">
        <svg class="units-search__icon" width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M12.5 12.5L16.5 16.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" class="units-search__input" id="unitSearch" placeholder="Search units..." aria-label="Search units">
      </div>
    </div>

    <div class="filter-pills" role="tablist" aria-label="Filter by size">
      <a href="/units" class="filter-pill<%= !size || size === 'all' ? ' filter-pill--active' : '' %>">All</a>
      <a href="/units?size=extra-small" class="filter-pill<%= size === 'extra-small' ? ' filter-pill--active' : '' %>">Extra Small</a>
      <a href="/units?size=small" class="filter-pill<%= size === 'small' ? ' filter-pill--active' : '' %>">Small</a>
      <a href="/units?size=medium" class="filter-pill<%= size === 'medium' ? ' filter-pill--active' : '' %>">Medium</a>
      <a href="/units?size=large" class="filter-pill<%= size === 'large' ? ' filter-pill--active' : '' %>">Large</a>
    </div>

    <p class="results-count" id="resultsCount">Showing <span id="visibleCount"><%= typeof units !== 'undefined' ? units.length : 0 %></span> of <%= typeof units !== 'undefined' ? units.length : 0 %> units</p>

    <% if (typeof units !== 'undefined' && units.length > 0) { %>
    <div class="grid grid--3" id="unitsGrid">
      <% units.forEach(function(u) { %>
      <% var unitSeed = u.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''); %>
      <div class="card unit-card" data-search="<%= u.name.toLowerCase() %> <%= u.size.toLowerCase() %>">
        <div class="unit-card__image-area">
          <img src="https://picsum.photos/seed/<%= unitSeed %>/400/300" alt="<%= u.name %>" class="card__image" loading="lazy" onerror="this.outerHTML='<div class=unit-card__image-placeholder></div>'">
        </div>
        <div class="card__body">
          <div class="card__meta">
            <% const badgeMap = { available: 'success', 'few-left': 'warning', unavailable: 'error' }; %>
            <span class="badge badge--<%= badgeMap[u.availability] || 'info' %>"><%= u.availability === 'few-left' ? 'Few Left' : u.availability.charAt(0).toUpperCase() + u.availability.slice(1) %></span>
            <span class="card__meta-item"><%= u.sqm %> m&sup2;</span>
          </div>
          <h3 class="card__title"><%= u.name %></h3>
          <p class="card__text unit-card__desc"><%= u.dimensions %>. <%= u.description || '' %></p>
          <div class="card__price"><%= currency %> <%= Number(u.price_monthly).toLocaleString('en-ZA') %><span class="card__price-label">/month</span></div>
          <% if (u.features && u.features.length) { %>
          <div class="card__features"><% u.features.forEach(function(f) { %><span class="card__feature"><%= f.replace(/-/g, ' ') %></span><% }); %></div>
          <% } %>
        </div>
        <div class="card__footer">
          <a href="/bookings/new?unit=<%= u.id %>" class="btn btn--primary btn--sm">Book Now</a>
          <% if (u.price_annual) { %><span class="text-mono text-dim text-xs"><%= currency %> <%= Number(u.price_annual).toLocaleString('en-ZA') %>/yr</span><% } %>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-search-x"/></svg></div>
      <h3 class="empty-state__title">No units match your criteria</h3>
      <p class="empty-state__text">Try adjusting your filters or check back later.</p>
      <a href="/units" class="btn btn--primary">Clear Filters</a>
    </div>
    <% } %>
  </div>
</section>
