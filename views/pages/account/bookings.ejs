<section class="page" data-animate="fade-in">
  <div class="container">
    <div class="account-layout">
      <aside class="account-sidebar">
        <nav aria-label="Account navigation">
          <a href="/account" class="account-nav-link">Overview</a>
          <a href="/account/bookings" class="account-nav-link active">My Rentals</a>
          <a href="/account/payments" class="account-nav-link">Payments</a>
          <a href="/account/profile" class="account-nav-link">Profile</a>
        </nav>
      </aside>

      <div class="account-main">
        <div class="flex items-center justify-between gap-4 mb-6">
          <div>
            <h1 class="page__title">My Rentals</h1>
            <p class="page__subtitle">Manage your active and past storage rentals</p>
          </div>
          <a href="/units" class="btn btn--primary">Rent Another Unit</a>
        </div>

        <div class="tab-nav" role="tablist" aria-label="Rental status filter">
          <button class="tab-nav__btn active" role="tab" aria-selected="true" data-tab="all">All (<%= typeof bookings !== 'undefined' ? bookings.length : 0 %>)</button>
          <button class="tab-nav__btn" role="tab" aria-selected="false" data-tab="active">Active (<%= typeof bookings !== 'undefined' ? bookings.filter(b => b.status === 'active').length : 0 %>)</button>
          <button class="tab-nav__btn" role="tab" aria-selected="false" data-tab="completed">Past (<%= typeof bookings !== 'undefined' ? bookings.filter(b => b.status === 'completed').length : 0 %>)</button>
          <button class="tab-nav__btn" role="tab" aria-selected="false" data-tab="cancelled">Cancelled (<%= typeof bookings !== 'undefined' ? bookings.filter(b => b.status === 'cancelled').length : 0 %>)</button>
        </div>

        <% if (typeof bookings !== 'undefined' && bookings.length > 0) { %>
        <div id="rental-cards-list">
          <% bookings.forEach(function(b) { %>
          <% const badgeMap = { active: 'success', completed: 'info', cancelled: 'error', expired: 'error' }; %>
          <div class="rental-card card card--static mb-4" data-status="<%= b.status %>">
            <div class="card__body">
              <div class="rental-card__header">
                <div class="rental-card__unit">
                  <h4 class="rental-card__name"><%= b.units ? b.units.name : 'Storage Unit' %></h4>
                  <p class="text-sm text-muted mt-1"><span class="text-mono"><%= b.reference %></span> &middot; <%= b.units ? b.units.sqm + ' m\u00B2' : '' %></p>
                </div>
                <span class="badge badge--<%= badgeMap[b.status] || 'info' %>"><%= b.status.charAt(0).toUpperCase() + b.status.slice(1) %></span>
              </div>
              <div class="rental-card__details">
                <div class="rental-card__detail">
                  <span class="rental-card__detail-label">Start Date</span>
                  <span class="rental-card__detail-value"><%= new Date(b.start_date).toLocaleDateString('en-ZA') %></span>
                </div>
                <div class="rental-card__detail">
                  <span class="rental-card__detail-label">End Date</span>
                  <span class="rental-card__detail-value"><%= new Date(b.end_date).toLocaleDateString('en-ZA') %></span>
                </div>
                <div class="rental-card__detail">
                  <span class="rental-card__detail-label">Duration</span>
                  <span class="rental-card__detail-value"><%= b.duration_months %> Month<%= b.duration_months > 1 ? 's' : '' %></span>
                </div>
                <div class="rental-card__detail">
                  <span class="rental-card__detail-label">Total</span>
                  <span class="rental-card__detail-value text-primary">R <%= Number(b.total_amount).toLocaleString('en-ZA') %></span>
                </div>
              </div>
              <div class="rental-card__actions">
                <a href="/bookings/<%= b.id %>" class="btn btn--outline btn--sm">View Details</a>
                <% if (b.status === 'active') { %>
                <a href="/payments/pay/<%= b.id %>" class="btn btn--primary btn--sm">Pay Now</a>
                <form action="/bookings/<%= b.id %>/cancel" method="POST" class="inline-form">
                  <button type="button" class="btn btn--ghost btn--sm js-cancel-btn" data-booking-id="<%= b.id %>" style="color:var(--clr-error);">Cancel</button>
                </form>
                <% } %>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
        <div id="rental-empty-state" class="empty-state hidden">
          <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-inbox"/></svg></div>
          <h3 class="empty-state__title">No rentals here</h3>
          <p class="empty-state__text" id="rental-empty-msg">No rentals match the selected filter.</p>
          <a href="/units" class="btn btn--primary">Browse Units</a>
        </div>
        <% } else { %>
        <div class="empty-state">
          <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-inbox"/></svg></div>
          <h3 class="empty-state__title">No rentals yet</h3>
          <p class="empty-state__text">You haven't rented any storage units yet. Browse our available units and get started today.</p>
          <a href="/units" class="btn btn--primary">Browse Units</a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<div id="cancel-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="cancel-modal-title" hidden>
  <div class="modal" style="max-width:440px;">
    <div class="modal__header">
      <h3 class="modal__title" id="cancel-modal-title">Cancel Booking</h3>
      <button class="modal__close" aria-label="Close modal">&times;</button>
    </div>
    <div class="modal__body">
      <p>Are you sure you want to cancel this booking? This action cannot be undone.</p>
      <p class="text-sm text-dim mt-2">Please note that according to our cancellation policy, 30 days' notice is required. A R150 admin fee may apply for monthly contracts.</p>
    </div>
    <div class="modal__footer">
      <button class="btn btn--outline modal-cancel">Keep Booking</button>
      <form id="cancel-form" action="" method="POST" style="display:inline;">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="btn btn--danger">Confirm Cancellation</button>
      </form>
    </div>
  </div>
</div>