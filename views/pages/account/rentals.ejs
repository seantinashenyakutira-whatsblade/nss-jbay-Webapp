<section class="page" data-animate="fade-in">
  <div class="container">
    <div class="account-layout">
      <aside class="account-sidebar">
        <nav aria-label="Account navigation">
          <a href="/account/dashboard" class="account-nav-link">Overview</a>
          <a href="/account/bookings" class="account-nav-link active">My Rentals</a>
          <a href="/account/payments" class="account-nav-link">Payments</a>
          <a href="/account/profile" class="account-nav-link">Profile</a>
        </nav>
      </aside>

      <div class="account-main">
        <div class="flex items-center justify-between gap-4 mb-8">
          <div>
            <h1 class="page__title">My Rentals</h1>
            <p class="page__subtitle">Manage your active and past storage rentals</p>
          </div>
          <a href="/units" class="btn btn--primary">Rent Another Unit</a>
        </div>

        <% if (typeof bookings !== 'undefined' && bookings.length > 0) { %>
          <% bookings.forEach(function(b) { %>
          <div class="rental-card card card--static mb-6">
            <div class="card__body">
              <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                  <h4><%= b.units ? b.units.name : 'Storage Unit' %></h4>
                  <p class="text-sm text-muted mt-2"><%= b.reference %> &middot; <%= b.units ? b.units.sqm + ' m\u00B2' : '' %></p>
                </div>
                <% const badgeMap = { active: 'success', completed: 'info', cancelled: 'error', expired: 'error' }; %>
                <span class="badge badge--<%= badgeMap[b.status] || 'info' %>"><%= b.status.charAt(0).toUpperCase() + b.status.slice(1) %></span>
              </div>
              <div class="rental-card__details" style="margin-top:16px;display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;">
                <div><span class="text-mono text-xs text-dim">Start Date</span><p class="text-sm"><%= new Date(b.start_date).toLocaleDateString('en-ZA') %></p></div>
                <div><span class="text-mono text-xs text-dim">End Date</span><p class="text-sm"><%= new Date(b.end_date).toLocaleDateString('en-ZA') %></p></div>
                <div><span class="text-mono text-xs text-dim">Duration</span><p class="text-sm"><%= b.duration_months %> Month<%= b.duration_months > 1 ? 's' : '' %></p></div>
                <div><span class="text-mono text-xs text-dim">Total</span><p class="text-sm text-primary">R <%= Number(b.total_amount).toLocaleString('en-ZA') %></p></div>
              </div>
              <div class="flex gap-3 mt-6">
                <a href="/bookings/<%= b.id %>" class="btn btn--outline btn--sm">View Details</a>
                <% if (b.status === 'active') { %>
                <form action="/bookings/<%= b.id %>/cancel" method="POST" onsubmit="return confirm('Are you sure you want to cancel this booking?');" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="btn btn--ghost btn--sm" style="color:var(--clr-error);">Cancel</button>
                </form>
                <% } %>
              </div>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-inbox"/></svg></div>
            <h3 class="empty-state__title">No rentals yet</h3>
            <p class="empty-state__text">You haven't rented any storage units yet. Browse our available units and get started today.</p>
            <a href="/units" class="btn btn--primary">Browse Units</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
