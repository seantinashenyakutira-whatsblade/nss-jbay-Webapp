<section class="page" data-animate="fade-in">
  <div class="container">
    <div class="account-layout">
      <aside class="account-sidebar">
        <nav aria-label="Account navigation">
          <a href="/account" class="account-nav-link">Overview</a>
          <a href="/account/bookings" class="account-nav-link">My Rentals</a>
          <a href="/account/payments" class="account-nav-link active">Payments</a>
          <a href="/account/profile" class="account-nav-link">Profile</a>
        </nav>
      </aside>

      <div class="account-main">
        <div class="flex items-center justify-between gap-4 mb-8">
          <div>
            <h1 class="page__title">Payment History</h1>
            <p class="page__subtitle">View all your past payments</p>
          </div>
          <div class="text-right">
            <p class="text-sm text-muted">Total Spent</p>
            <p class="text-2xl font-heading text-primary">R <%= typeof totalSpent !== 'undefined' ? Number(totalSpent).toLocaleString('en-ZA') : '0' %></p>
          </div>
        </div>

        <% if (typeof payments !== 'undefined' && payments.length > 0) { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Date</th><th>Reference</th><th>Booking</th><th>Amount</th><th>Status</th><th>Card</th><th>Invoice</th></tr>
            </thead>
            <tbody>
              <% payments.forEach(function(p) { %>
              <tr>
                <td><%= new Date(p.created_at).toLocaleDateString('en-ZA') %></td>
                <td class="text-mono"><%= p.reference %></td>
                <td><%= p.bookings ? p.bookings.reference : 'Storage Rental' %></td>
                <td class="text-primary font-heading">R <%= Number(p.amount).toLocaleString('en-ZA') %></td>
                <td>
                  <% const badgeMap = { pending: 'warning', completed: 'success', failed: 'error', refunded: 'info' }; %>
                  <span class="badge badge--<%= badgeMap[p.status] || 'info' %>"><%= p.status.charAt(0).toUpperCase() + p.status.slice(1) %></span>
                </td>
                <td class="text-sm"><%= p.card_brand ? (p.card_brand.charAt(0).toUpperCase() + p.card_brand.slice(1) + ' ****' + (p.card_last_four || '')) : (p.status === 'failed' ? '—' : '—') %></td>
                <td>
                  <button type="button" class="btn btn--ghost btn--sm js-download-invoice" data-payment-id="<%= p.id %>" data-reference="<%= p.reference %>" title="Download Invoice">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state">
          <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-credit-card"/></svg></div>
          <h3 class="empty-state__title">No payments yet</h3>
          <p class="empty-state__text">Payment records will appear here once you rent a storage unit.</p>
          <a href="/units" class="btn btn--primary">Browse Units</a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<div id="invoice-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="invoice-modal-title" hidden>
  <div class="modal" style="max-width:600px;max-height:90vh;overflow-y:auto;">
    <div class="modal__header">
      <h3 class="modal__title" id="invoice-modal-title">Invoice</h3>
      <button class="modal__close" aria-label="Close">&times;</button>
    </div>
    <div class="modal__body" id="invoice-content" style="padding:0;">
    </div>
    <div class="modal__footer">
      <button class="btn btn--outline modal-cancel">Close</button>
      <button class="btn btn--primary" id="print-invoice-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="vertical-align:middle;margin-right:4px;"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Print / Download
      </button>
    </div>
  </div>
</div>