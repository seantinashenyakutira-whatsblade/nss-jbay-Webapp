<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1><%= typeof unit !== 'undefined' ? 'Edit Unit' : 'Add New Unit' %></h1>
        <p class="text-sm text-muted"><%= typeof unit !== 'undefined' ? 'Update unit details' : 'Create a new storage unit' %></p>
      </div>
    </div>

    <form action="<%= typeof unit !== 'undefined' ? '/admin/units/' + unit.id : '/admin/units' %>" method="POST" enctype="multipart/form-data" style="max-width:960px;">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="grid grid--2" style="gap:var(--space-8);">
        <div>
          <div class="form-group">
            <label class="form-label form-label--required" for="unitName">Unit Name</label>
            <input type="text" id="unitName" name="name" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.name : '' %>" placeholder="e.g. Extra Small &mdash; Essentials" required>
          </div>
          <div class="form-group">
            <label class="form-label form-label--required" for="unitSize">Size Category</label>
            <select id="unitSize" name="size" class="form-select" required>
              <option value="extra-small" <%= typeof unit !== 'undefined' && unit.size === 'extra-small' ? 'selected' : '' %>>Extra Small</option>
              <option value="small" <%= typeof unit !== 'undefined' && unit.size === 'small' ? 'selected' : '' %>>Small</option>
              <option value="medium" <%= typeof unit !== 'undefined' && unit.size === 'medium' ? 'selected' : '' %>>Medium</option>
              <option value="large" <%= typeof unit !== 'undefined' && unit.size === 'large' ? 'selected' : '' %>>Large</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label form-label--required" for="unitSqm">Square Meters</label>
              <input type="number" id="unitSqm" name="sqm" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.sqm : '' %>" required>
            </div>
            <div class="form-group">
              <label class="form-label form-label--required" for="unitDims">Dimensions</label>
              <input type="text" id="unitDims" name="dimensions" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.dimensions : '' %>" placeholder="3m &times; 2m &times; 2.4m" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="unitDesc">Description</label>
            <textarea id="unitDesc" name="description" class="form-textarea" placeholder="Describe the unit..."><%= typeof unit !== 'undefined' ? unit.description : '' %></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label form-label--required" for="unitPriceMonthly">Monthly Price (R)</label>
              <input type="number" step="0.01" id="unitPriceMonthly" name="price_monthly" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.price_monthly : '' %>" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="unitPriceAnnual">Annual Price (R)</label>
              <input type="number" step="0.01" id="unitPriceAnnual" name="price_annual" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.price_annual : '' %>">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="unitBlock">Block / Section</label>
            <input type="text" id="unitBlock" name="block_section" class="form-input" value="<%= typeof unit !== 'undefined' ? unit.block_section : '' %>" placeholder="A, B, C, D">
          </div>
        </div>

        <div>
          <div class="form-group">
            <label class="form-label" for="unitImage">Unit Image</label>
            <input type="file" id="unitImage" name="image" class="form-input" accept="image/jpeg,image/png,image/webp" onchange="previewImage(event)">
            <div id="imagePreview" style="margin-top:12px;width:100%;height:180px;background:var(--clr-bg-alt);border-radius:var(--radius-sm);border:1px solid var(--clr-border);display:flex;align-items:center;justify-content:center;overflow:hidden;">
              <svg class="icon icon--xl icon--muted" aria-hidden="true"><use href="#icon-image"/></svg>
              <span class="text-mono text-dim text-xs" style="margin-left:8px;">Image preview</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label form-label--required">Availability</label>
            <div style="display:flex;gap:12px;margin-top:8px;">
              <label class="form-radio"><input type="radio" name="availability" value="available" <%= typeof unit === 'undefined' || unit.availability === 'available' ? 'checked' : '' %>> Available</label>
              <label class="form-radio"><input type="radio" name="availability" value="few-left" <%= typeof unit !== 'undefined' && unit.availability === 'few-left' ? 'checked' : '' %>> Few Left</label>
              <label class="form-radio"><input type="radio" name="availability" value="unavailable" <%= typeof unit !== 'undefined' && unit.availability === 'unavailable' ? 'checked' : '' %>> Unavailable</label>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Features</label>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;">
              <% var featureOptions = ['ground-floor','cctv','drive-up','double-door','climate','security']; %>
              <% featureOptions.forEach(function(opt) { %>
                <% var checked = typeof unit !== 'undefined' && unit.features && unit.features.includes(opt); %>
                <label class="form-checkbox"><input type="checkbox" name="features" value="<%= opt %>" <%= checked ? 'checked' : '' %>> <%= opt.replace(/-/g, ' ') %></label>
              <% }); %>
            </div>
          </div>
          <div class="form-group" style="margin-top:32px;">
            <button type="submit" class="btn btn--primary btn--lg btn--block"><%= typeof unit !== 'undefined' ? 'Update Unit' : 'Publish Unit' %></button>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>
