<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1>Bulk Pricing</h1>
        <p class="text-sm text-muted">Update pricing for all units by size category</p>
      </div>
    </div>

    <div class="grid grid--2" style="gap:var(--space-6);">
      <% var sizeConfig = [
        { key: 'extra-small', label: 'Extra Small', icon: 'XS' },
        { key: 'small', label: 'Small', icon: 'S' },
        { key: 'medium', label: 'Medium', icon: 'M' },
        { key: 'large', label: 'Large', icon: 'L' },
      ]; %>
      <% sizeConfig.forEach(function(s) { %>
      <div class="card card--static">
        <div class="card__body">
          <div class="flex items-center gap-4 mb-4">
            <div style="width:48px;height:48px;border-radius:var(--radius-sm);background:var(--clr-primary-light);display:flex;align-items:center;justify-content:center;font-family:var(--font-heading);font-size:1.5rem;color:var(--clr-primary);"><%= s.icon %></div>
            <div><h4><%= s.label %></h4><p class="text-xs text-muted"><%= typeof units !== 'undefined' ? units.filter(function(u) { return u.size === s.key; }).length : 0 %> units</p></div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label text-xs">Monthly Rate (R)</label>
              <input type="number" class="form-input" style="padding:8px 12px;font-size:var(--text-sm);" placeholder="e.g. 450" data-size="<%= s.key %>" data-type="monthly">
            </div>
            <div class="form-group">
              <label class="form-label text-xs">Annual Rate (R)</label>
              <input type="number" class="form-input" style="padding:8px 12px;font-size:var(--text-sm);" placeholder="e.g. 4500" data-size="<%= s.key %>" data-type="annual">
            </div>
          </div>
          <button class="btn btn--primary btn--sm btn--block" onclick="updateBulkPricing('<%= s.key %>')">Update All <%= s.label %> Units</button>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>
