<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1>Payments</h1>
        <p class="text-sm text-muted">All payment transactions</p>
      </div>
      <div class="text-right">
        <p class="text-sm text-muted">Total Revenue</p>
        <p class="text-2xl font-heading text-primary">R <%= typeof totalRevenue !== 'undefined' ? Number(totalRevenue).toLocaleString('en-ZA') : '0' %></p>
      </div>
    </div>

    <div class="flex gap-4 mb-6 flex-wrap">
      <div class="form-group" style="margin:0;">
        <label class="form-label text-xs">From</label>
        <input type="date" class="form-input" style="width:auto;padding:8px 12px;font-size:var(--text-sm);" id="paymentsFrom">
      </div>
      <div class="form-group" style="margin:0;">
        <label class="form-label text-xs">To</label>
        <input type="date" class="form-input" style="width:auto;padding:8px 12px;font-size:var(--text-sm);" id="paymentsTo">
      </div>
      <div class="form-group" style="margin:0;align-self:flex-end;">
        <button class="btn btn--secondary btn--sm" onclick="filterPayments()">Filter</button>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Date</th><th>Reference</th><th>Booking</th><th>Customer</th><th>Method</th><th>Card</th><th>Amount</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% if (typeof payments !== 'undefined' && payments.length > 0) { %>
            <% payments.forEach(function(p) { %>
            <tr>
              <td><%= new Date(p.created_at).toLocaleDateString('en-ZA') %></td>
              <td class="text-mono"><%= p.reference %></td>
              <td><%= p.bookings ? p.bookings.reference : 'N/A' %></td>
              <td><%= p.profiles ? p.profiles.email : 'N/A' %></td>
              <td class="text-capitalize"><%= p.payment_method %></td>
              <td><%= p.card_brand ? (p.card_brand.charAt(0).toUpperCase() + p.card_brand.slice(1) + ' ****' + (p.card_last_four || '')) : '—' %></td>
              <td>R <%= Number(p.amount).toLocaleString('en-ZA') %></td>
              <td>
                <% const badgeMap = { pending: 'warning', completed: 'success', failed: 'error', refunded: 'info' }; %>
                <span class="badge badge--<%= badgeMap[p.status] || 'info' %>"><%= p.status.charAt(0).toUpperCase() + p.status.slice(1) %></span>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="text-center text-dim">No payments found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
