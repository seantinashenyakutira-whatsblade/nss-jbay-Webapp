<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1>Manage Bookings</h1>
        <p class="text-sm text-muted"><%= typeof bookings !== 'undefined' ? bookings.length : 0 %> total</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/bookings?status=all" class="filter-pill filter-pill--sm<%= !status || status === 'all' ? ' filter-pill--active' : '' %>">All</a>
        <a href="/admin/bookings?status=active" class="filter-pill filter-pill--sm<%= status === 'active' ? ' filter-pill--active' : '' %>">Active</a>
        <a href="/admin/bookings?status=completed" class="filter-pill filter-pill--sm<%= status === 'completed' ? ' filter-pill--active' : '' %>">Completed</a>
        <a href="/admin/bookings?status=cancelled" class="filter-pill filter-pill--sm<%= status === 'cancelled' ? ' filter-pill--active' : '' %>">Cancelled</a>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Ref</th><th>Customer</th><th>Unit</th><th>Dates</th><th>Amount</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% if (typeof bookings !== 'undefined' && bookings.length > 0) { %>
            <% bookings.forEach(function(b) { %>
            <tr>
              <td class="text-mono"><%= b.reference %></td>
              <td><%= b.profiles ? b.profiles.email : 'N/A' %></td>
              <td><%= b.units ? b.units.name : 'N/A' %></td>
              <td><%= new Date(b.start_date).toLocaleDateString('en-ZA') %> &mdash; <%= new Date(b.end_date).toLocaleDateString('en-ZA') %></td>
              <td>R <%= Number(b.total_amount).toLocaleString('en-ZA') %></td>
              <td>
                <select class="form-select" style="width:auto;min-width:120px;padding:4px 28px 4px 8px;font-size:var(--text-xs);" onchange="updateBookingStatus('<%= b.id %>', this.value)">
                  <option value="active" <%= b.status === 'active' ? 'selected' : '' %>>Active</option>
                  <option value="completed" <%= b.status === 'completed' ? 'selected' : '' %>>Completed</option>
                  <option value="cancelled" <%= b.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                  <option value="expired" <%= b.status === 'expired' ? 'selected' : '' %>>Expired</option>
                </select>
              </td>
              <td><a href="/bookings/<%= b.id %>" class="btn btn--ghost btn--sm">View</a></td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="7" class="text-center text-dim">No bookings found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
