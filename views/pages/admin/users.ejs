<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1>Manage Users</h1>
        <p class="text-sm text-muted"><%= typeof customers !== 'undefined' ? customers.length : 0 %> registered users</p>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Name</th><th>Email</th><th>Phone</th><th>Admin</th><th>Joined</th></tr>
        </thead>
        <tbody>
          <% if (typeof customers !== 'undefined' && customers.length > 0) { %>
            <% customers.forEach(function(c) { %>
            <tr>
              <td><%= c.first_name || '' %> <%= c.last_name || '' %></td>
              <td><%= c.email || '&mdash;' %></td>
              <td><%= c.phone || '&mdash;' %></td>
              <td><span class="badge badge--<%= c.is_admin ? 'success' : 'neutral' %>"><%= c.is_admin ? 'Yes' : 'No' %></span></td>
              <td><%= c.created_at ? new Date(c.created_at).toLocaleDateString('en-ZA') : '&mdash;' %></td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center text-dim">No users found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
