<div class="admin-layout" data-animate="fade-in">
  <aside class="admin-sidebar">
    <div class="admin-sidebar__badge">ADMIN</div>
    <a href="/admin" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-layout-dashboard"/></svg> Dashboard</a>
    <a href="/admin/units" class="admin-sidebar__link active"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-building-2"/></svg> Manage Units</a>
    <a href="/admin/bookings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-calendar"/></svg> Manage Bookings</a>
    <a href="/admin/payments" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-credit-card"/></svg> Payments</a>
    <a href="/admin/customers" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-user"/></svg> Customers</a>
    <a href="/admin/pricing" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-dollar-sign"/></svg> Pricing</a>
    <a href="/admin/settings" class="admin-sidebar__link"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-settings"/></svg> Settings</a>
    <div class="admin-sidebar__divider"></div>
    <a href="/" class="admin-sidebar__link admin-sidebar__link--back"><svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-arrow-left"/></svg> View Site</a>
  </aside>

  <div class="admin-main">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <h1>Manage Units</h1>
        <p class="text-sm text-muted"><%= typeof units !== 'undefined' ? units.length : 0 %> units</p>
      </div>
      <a href="/admin/units/new" class="btn btn--primary">Add New Unit</a>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Name</th><th>Size</th><th>Price</th><th>Block</th><th>Availability</th><th>Active</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% if (typeof units !== 'undefined' && units.length > 0) { %>
            <% units.forEach(function(u) { %>
            <tr>
              <td><%= u.name %></td>
              <td class="text-capitalize"><%= u.size %> (<%= u.sqm %> m&sup2;)</td>
              <td>R <%= Number(u.price_monthly).toLocaleString('en-ZA') %>/mo</td>
              <td><%= u.block_section || '&mdash;' %></td>
              <td>
                <% const badgeMap = { available: 'success', 'few-left': 'warning', unavailable: 'error' }; %>
                <span class="badge badge--<%= badgeMap[u.availability] || 'info' %>"><%= u.availability === 'few-left' ? 'Few Left' : u.availability.charAt(0).toUpperCase() + u.availability.slice(1) %></span>
              </td>
              <td><span class="badge badge--<%= u.is_active ? 'success' : 'error' %>"><%= u.is_active ? 'Yes' : 'No' %></span></td>
              <td>
                <div class="flex gap-2">
                  <a href="/admin/units/<%= u.id %>/edit" class="btn btn--ghost btn--sm">Edit</a>
                  <% if (u.is_active) { %>
                  <button class="btn btn--ghost btn--sm" style="color:var(--clr-error);" onclick="confirmDelete('<%= u.id %>')">Delete</button>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="7" class="text-center text-dim">No units found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
