<section class="section" style="padding-top:calc(var(--header-height) + 48px);">
  <div class="container">
    <div style="max-width:760px;margin:0 auto;">
      <a href="/units" style="color:var(--clr-text-muted);font-size:0.875rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:24px;text-decoration:none;"><svg class="icon icon--sm" aria-hidden="true"><use href="#icon-arrow-left"/></svg> Back to Units</a>

      <% if (typeof unit !== 'undefined' && unit) { %>
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:16px;margin-bottom:32px;">
        <div>
          <h1 style="margin-bottom:4px;"><%= unit.name %></h1>
          <p class="text-mono text-dim"><%= unit.sqm %> m&sup2; &mdash; <%= unit.dimensions %></p>
        </div>
        <span class="badge badge--<%= unit.availability === 'available' ? 'success' : unit.availability === 'few-left' ? 'warning' : 'error' %>"><%= unit.availability === 'few-left' ? 'Few Left' : unit.availability.charAt(0).toUpperCase() + unit.availability.slice(1) %></span>
      </div>

      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <div class="card__price" style="font-size:3rem;">
            <%= currency %> <%= Number(unit.price_monthly).toLocaleString('en-ZA') %>
            <span class="card__price-label">/month</span>
          </div>
          <% if (unit.price_annual) { %><p class="text-mono text-dim" style="margin-top:4px;"><%= currency %> <%= Number(unit.price_annual).toLocaleString('en-ZA') %> per year &mdash; save up to 15%</p><% } %>
        </div>
      </div>

      <% if (unit.description) { %>
      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <h4 style="margin-bottom:8px;">Description</h4>
          <p style="color:var(--clr-text-muted);font-size:0.9375rem;line-height:1.7;"><%= unit.description %></p>
        </div>
      </div>
      <% } %>

      <% if (unit.features && unit.features.length > 0) { %>
      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <h4 style="margin-bottom:12px;">Features</h4>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <% unit.features.forEach(function(f) { %>
            <span class="card__feature" style="font-size:0.8125rem;padding:6px 14px;"><%= f.replace(/-/g, ' ') %></span>
            <% }); %>
          </div>
        </div>
      </div>
      <% } %>

      <div style="display:flex;gap:12px;">
        <a href="/bookings/new?unit=<%= unit.id %>" class="btn btn--primary btn--lg">Book This Unit</a>
        <a href="/units" class="btn btn--outline btn--lg">View All Units</a>
      </div>
      <% } else { %>
      <div class="text-center" style="padding:60px 0;">
        <h2>Unit Not Found</h2>
        <p style="color:var(--clr-text-muted);margin:16px 0;">This unit doesn't exist or has been removed.</p>
        <a href="/units" class="btn btn--primary">Browse Units</a>
      </div>
      <% } %>
    </div>
  </div>
</section>
