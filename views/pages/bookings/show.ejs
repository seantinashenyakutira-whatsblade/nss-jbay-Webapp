<section class="section" style="padding-top:calc(var(--header-height) + 48px);">
  <div class="container">
    <div style="max-width:760px;margin:0 auto;">
      <a href="/account/bookings" style="color:var(--clr-text-muted);font-size:0.875rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:24px;text-decoration:none;">
        <svg class="icon icon--sm" aria-hidden="true"><use href="#icon-arrow-left"/></svg> Back to My Bookings
      </a>

      <% if (typeof booking !== 'undefined' && booking) { %>
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:16px;margin-bottom:32px;">
        <div>
          <h1 style="margin-bottom:4px;">Booking Details</h1>
          <p class="text-mono text-dim">Reference: <%= booking.reference %></p>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <% const sMap = { active: 'success', completed: 'info', cancelled: 'error', expired: 'error' }; %>
          <span class="badge badge--<%= sMap[booking.status] || 'info' %>"><%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %></span>
          <a href="javascript:void(0)" class="btn btn--outline btn--sm" onclick="window.print()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="vertical-align:middle;margin-right:4px;"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Download Invoice
          </a>
        </div>
      </div>

      <div class="grid grid--2" style="margin-bottom:32px;">
        <div class="card card--static">
          <div class="card__body">
            <h4 style="margin-bottom:12px;">Unit Information</h4>
            <div style="color:var(--clr-text-muted);font-size:0.875rem;">
              <p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">Unit:</strong> <%= booking.units ? booking.units.name : 'N/A' %></p>
              <p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">Size:</strong> <%= booking.units ? booking.units.sqm + ' m\u00B2 (' + booking.units.dimensions + ')' : 'N/A' %></p>
              <% if (booking.units && booking.units.block_section) { %><p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">Block:</strong> <%= booking.units.block_section %></p><% } %>
              <p><strong style="color:var(--clr-text);">Monthly Rate:</strong> R <%= Number(booking.monthly_rate).toLocaleString('en-ZA') %></p>
            </div>
          </div>
        </div>
        <div class="card card--static">
          <div class="card__body">
            <h4 style="margin-bottom:12px;">Rental Period</h4>
            <div style="color:var(--clr-text-muted);font-size:0.875rem;">
              <p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">Start:</strong> <%= new Date(booking.start_date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              <p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">End:</strong> <%= new Date(booking.end_date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              <p style="margin-bottom:8px;"><strong style="color:var(--clr-text);">Duration:</strong> <%= booking.duration_months %> Month<%= booking.duration_months > 1 ? 's' : '' %></p>
              <p><strong style="color:var(--clr-text);">Created:</strong> <%= new Date(booking.created_at).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <h4 style="margin-bottom:12px;">Payment Summary</h4>
          <div style="color:var(--clr-text-muted);font-size:0.875rem;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span>Monthly Rate (&times;<%= booking.duration_months %>)</span><span>R <%= Number(booking.monthly_rate * booking.duration_months).toLocaleString('en-ZA') %></span></div>
            <% if (booking.discount_applied > 0) { %><div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span>Discount</span><span style="color:var(--clr-success);">&minus;R <%= Number(booking.discount_applied).toLocaleString('en-ZA') %></span></div><% } %>
            <div style="display:flex;justify-content:space-between;font-size:1.125rem;font-weight:500;border-top:1px solid var(--clr-border);padding-top:12px;margin-top:8px;">
              <span style="color:var(--clr-text);">Total</span><span style="color:var(--clr-primary);">R <%= Number(booking.total_amount).toLocaleString('en-ZA') %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <h4 style="margin-bottom:12px;">Booking Timeline</h4>
          <div class="booking-timeline">
            <div class="timeline-item <%= booking.created_at ? 'timeline-item--done' : '' %>">
              <div class="timeline-item__marker"></div>
              <div class="timeline-item__content">
                <p class="timeline-item__title">Booking Created</p>
                <p class="timeline-item__date text-mono text-xs text-dim"><%= new Date(booking.created_at).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              </div>
            </div>
            <% if (booking.status === 'active') { %>
            <div class="timeline-item timeline-item--active">
              <div class="timeline-item__marker"></div>
              <div class="timeline-item__content">
                <p class="timeline-item__title">Rental Active</p>
                <p class="timeline-item__date text-mono text-xs text-dim"><%= new Date(booking.start_date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              </div>
            </div>
            <% } else if (booking.status === 'completed') { %>
            <div class="timeline-item timeline-item--done">
              <div class="timeline-item__marker"></div>
              <div class="timeline-item__content">
                <p class="timeline-item__title">Rental Completed</p>
              </div>
            </div>
            <% } else if (booking.status === 'cancelled') { %>
            <div class="timeline-item timeline-item--cancelled">
              <div class="timeline-item__marker"></div>
              <div class="timeline-item__content">
                <p class="timeline-item__title">Booking Cancelled</p>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <% if (typeof payments !== 'undefined' && payments.length > 0) { %>
      <div class="card card--static" style="margin-bottom:24px;">
        <div class="card__body">
          <h4 style="margin-bottom:12px;">Payment History</h4>
          <% payments.forEach(function(p) { %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--clr-border);font-size:0.875rem;">
            <div>
              <p class="text-mono text-sm"><%= p.reference %></p>
              <p class="text-xs text-dim"><%= new Date(p.created_at).toLocaleDateString('en-ZA') %></p>
              <% if (p.card_brand) { %><p class="text-xs text-dim" style="margin-top:2px;"><%= p.card_brand.charAt(0).toUpperCase() + p.card_brand.slice(1) %> ****<%= p.card_last_four || '' %></p><% } %>
            </div>
            <div style="text-align:right;">
              <p class="text-primary font-heading">R <%= Number(p.amount).toLocaleString('en-ZA') %></p>
              <% const pMap = { pending: 'warning', completed: 'success', failed: 'error', refunded: 'info' }; %>
              <span class="badge badge--<%= pMap[p.status] || 'info' %>"><%= p.status %></span>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/account/bookings" class="btn btn--outline">Back to Bookings</a>
        <% if (booking.status === 'active') { %>
        <a href="/payments/pay/<%= booking.id %>" class="btn btn--primary">Make Payment</a>
        <form action="/bookings/<%= booking.id %>/cancel" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn--ghost" style="color:var(--clr-error);">Cancel Booking</button>
        </form>
        <% } %>
      </div>
      <% } else { %>
      <div class="text-center" style="padding:60px 0;">
        <h2>Booking Not Found</h2>
        <p style="color:var(--clr-text-muted);margin:16px 0;">This booking doesn't exist or has been removed.</p>
        <a href="/account/bookings" class="btn btn--primary">My Bookings</a>
      </div>
      <% } %>
    </div>
  </div>
</section>

<style>
.booking-timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-left: 24px;
  border-left: 2px solid var(--clr-border);
  margin-top: 8px;
}

.timeline-item {
  position: relative;
  padding: 0 0 20px 20px;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item__marker {
  position: absolute;
  left: -29px;
  top: 0;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--clr-bg-card);
  border: 2px solid var(--clr-border);
}

.timeline-item--done .timeline-item__marker {
  background: var(--clr-success);
  border-color: var(--clr-success);
}

.timeline-item--active .timeline-item__marker {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  animation: pulse 2s ease-in-out infinite;
}

.timeline-item--cancelled .timeline-item__marker {
  background: var(--clr-error);
  border-color: var(--clr-error);
}

.timeline-item__title {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--clr-text);
  margin-bottom: 2px;
}

.timeline-item--cancelled .timeline-item__title {
  color: var(--clr-error);
}
</style>