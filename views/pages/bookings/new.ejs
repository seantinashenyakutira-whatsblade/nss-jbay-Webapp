<section class="section" style="padding-top:calc(var(--header-height) + 48px);">
  <div class="container">
    <div style="max-width:640px;margin:0 auto;">
      <h1 style="margin-bottom:8px;">New Booking</h1>
      <p style="color:var(--clr-text-muted);margin-bottom:32px;">Select your unit and rental period</p>

      <form action="/bookings" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-group">
          <label class="form-label form-label--required" for="unitId">Storage Unit</label>
          <select id="unitId" name="unitId" class="form-select" required>
            <option value="">Select a unit...</option>
            <% if (typeof units !== 'undefined' && units.length > 0) { %>
              <% units.forEach(function(u) { %>
                <option value="<%= u.id %>" <%= preselected === u.id ? 'selected' : '' %>><%= u.name %> &mdash; R <%= Number(u.price_monthly).toLocaleString('en-ZA') %>/month</option>
              <% }); %>
            <% } else { %>
              <option value="extra-small-essentials">Extra Small &mdash; Essentials (R 450/month)</option>
              <option value="extra-small-compact">Extra Small &mdash; Compact (R 450/month)</option>
              <option value="small-starter">Small &mdash; Starter (R 750/month)</option>
              <option value="small-business">Small &mdash; Business (R 750/month)</option>
              <option value="medium-family">Medium &mdash; Family (R 1 200/month)</option>
              <option value="medium-commercial">Medium &mdash; Commercial (R 1 200/month)</option>
              <option value="large-mega">Large &mdash; Mega (R 1 800/month)</option>
              <option value="large-enterprise">Large &mdash; Enterprise (R 1 800/month)</option>
            <% } %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label form-label--required" for="duration">Rental Duration</label>
          <select id="duration" name="duration" class="form-select" required>
            <option value="1">1 Month &mdash; Full price</option>
            <option value="3">3 Months &mdash; 5% discount</option>
            <option value="6">6 Months &mdash; 10% discount</option>
            <option value="12">12 Months &mdash; 15% discount</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label form-label--required" for="startDate">Start Date</label>
          <input type="date" id="startDate" name="startDate" class="form-input" required value="<%= new Date().toISOString().split('T')[0] %>">
        </div>

        <div id="booking-summary" style="background:var(--clr-bg-alt);border:1px solid var(--clr-border);border-radius:var(--radius-md);padding:20px;margin-bottom:24px;">
          <div class="summary-row" style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.875rem;color:var(--clr-text-muted);">
            <span>Monthly Rate</span><span>&mdash;</span>
          </div>
          <div class="summary-row" style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.875rem;color:var(--clr-text-muted);">
            <span>Discount</span><span style="color:var(--clr-success);">&mdash;</span>
          </div>
          <div class="summary-total" style="display:flex;justify-content:space-between;font-size:1.125rem;font-weight:500;border-top:1px solid var(--clr-border);padding-top:12px;margin-top:8px;">
            <span>Total</span><span style="color:var(--clr-primary);">&mdash;</span>
          </div>
        </div>

        <% if (!user) { %>
          <div style="background:var(--clr-bg-alt);border:1px solid var(--clr-border);border-radius:var(--radius-md);padding:20px;margin-bottom:24px;">
            <p style="font-size:0.875rem;color:var(--clr-text-muted);margin-bottom:12px;">You need to be logged in to book a unit.</p>
            <a href="/auth/login?redirect=/bookings/new" class="btn btn--primary btn--block">Log in to Continue</a>
            <p style="text-align:center;margin-top:12px;font-size:0.8125rem;color:var(--clr-text-dim);">Don't have an account? <a href="/auth/register?redirect=/bookings/new">Sign up</a></p>
          </div>
        <% } else { %>
          <button type="submit" class="btn btn--primary btn--block btn--lg">Confirm Booking</button>
        <% } %>
      </form>
    </div>
  </div>
</section>
