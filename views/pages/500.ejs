<div class="error-page" data-animate="fade-in">
  <div class="error-page__code">500</div>
  <h1 class="error-page__title">Something went wrong</h1>
  <p class="error-page__message"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again later.' %></p>
  <a href="/" class="btn btn--primary btn--lg">Go Home</a>
</div>
