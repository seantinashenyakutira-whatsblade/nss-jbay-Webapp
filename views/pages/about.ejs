<section class="page" data-animate="fade-in">
  <div class="container" style="max-width:800px;">
    <div class="page__header text-center">
      <h1 class="page__title">About Us</h1>
      <p class="page__subtitle">Your trusted self-storage partner in Jeffrey's Bay</p>
    </div>
  </div>
</section>

<section class="section section--sm" style="padding-top:0;" data-animate="fade-in-up">
  <div class="container" style="max-width:800px;">
    <div class="grid grid--2" style="gap:48px;align-items:center;">
      <div>
        <h3>Our Story</h3>
        <p style="color:var(--clr-text-muted);line-height:1.8;">National Secure Storage &mdash; Jeffrey's Bay is part of a trusted South African self-storage network dedicated to providing secure, affordable, and flexible storage solutions for residents and businesses in the Eastern Cape.</p>
        <p style="color:var(--clr-text-muted);line-height:1.8;margin-top:16px;">Our facility at 35 St Croix Street offers a range of unit sizes from extra-small (6 m&sup2;) to large (27 m&sup2;), suitable for everything from a few boxes to the contents of a large home.</p>
      </div>
        <div class="about-image-placeholder">
          <img src="https://picsum.photos/seed/nss-jbay-facility/600/400" alt="National Secure Storage facility" style="width:100%;height:300px;object-fit:cover;border-radius:var(--radius-lg);border:1px solid var(--clr-border);" loading="lazy">
        </div>
    </div>
  </div>
</section>

<section class="section section--sm section--alt" data-animate="fade-in-up">
  <div class="container">
    <div class="section__header">
      <h3>Security Features</h3>
      <p class="section__subtitle">Your belongings are protected at every level</p>
    </div>
    <div class="grid grid--3">
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-building-2"/></svg></div>
          <h4>24/7 CCTV Surveillance</h4>
          <p class="card__text">High-definition cameras monitor all areas of our facility around the clock. Recorded footage is securely stored.</p>
        </div>
      </div>
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-shield-alert"/></svg></div>
          <h4>Perimeter Electric Fencing</h4>
          <p class="card__text">Our facility is secured with electric fencing and controlled access gates to prevent unauthorized entry.</p>
        </div>
      </div>
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-key"/></svg></div>
          <h4>Secure Access Control</h4>
          <p class="card__text">Only authorized tenants can access the facility during business hours. Each unit has its own lock.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--sm" data-animate="fade-in-up">
  <div class="container">
    <div class="section__header">
      <h3>Why Jeffrey's Bay?</h3>
      <p class="section__subtitle">The perfect location for your storage needs</p>
    </div>
    <div class="grid grid--3">
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-mountain"/></svg></div>
          <h4>Growing Community</h4>
          <p class="card__text">Jeffrey's Bay is one of the fastest-growing coastal towns in the Eastern Cape. More residents and businesses mean more storage needs.</p>
        </div>
      </div>
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-trees"/></svg></div>
          <h4>Coastal Lifestyle</h4>
          <p class="card__text">Seasonal residents, surfers, and holidaymakers need reliable storage for their belongings between visits to JBay.</p>
        </div>
      </div>
      <div class="card card--static">
        <div class="card__body text-center">
          <div class="feature-icon"><svg class="icon icon--xxl icon--primary" aria-hidden="true"><use href="#icon-factory"/></svg></div>
          <h4>Business Hub</h4>
          <p class="card__text">Local businesses need inventory and equipment storage. Our flexible terms make it easy for startups and established companies alike.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--sm" data-animate="fade-in-up">
  <div class="container" style="max-width:800px;">
    <div class="grid grid--2" style="gap:48px;align-items:center;">
        <div>
          <img src="https://picsum.photos/seed/nss-jbay-map/600/400" alt="Map showing NSS JBay location" style="width:100%;height:250px;object-fit:cover;border-radius:var(--radius-lg);border:1px solid var(--clr-border);" loading="lazy">
        </div>
      <div>
        <h3>Our Location</h3>
        <p style="color:var(--clr-text-muted);line-height:1.8;"><%= typeof siteAddress !== 'undefined' ? siteAddress : '35 St Croix Street, Jeffrey\'s Bay, Eastern Cape, 6330' %></p>
        <p style="color:var(--clr-text-muted);line-height:1.8;margin-top:12px;">Conveniently located in the heart of Jeffrey's Bay, we're easy to find and offer drive-up access for hassle-free loading and unloading.</p>
      </div>
    </div>
  </div>
</section>
