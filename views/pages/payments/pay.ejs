<section class="page" style="padding-top:calc(var(--header-height) + 48px);">
  <div class="container paywall-container">
      <a href="/account/bookings" class="back-link" style="display:inline-flex;align-items:center;gap:8px;color:var(--clr-text-dim);font-size:0.875rem;margin-bottom:24px;text-decoration:none;">
        <svg class="icon icon--sm" aria-hidden="true"><use href="#icon-arrow-left"/></svg> Back to My Bookings
      </a>

    <% if (typeof booking !== 'undefined' && booking) { %>
    <div class="payment-card" id="payment-form-container">
      <h1 style="font-family:var(--font-heading);font-size:var(--text-3xl);margin-bottom:8px;">Complete Your Payment</h1>
      <p class="text-dim text-sm mb-6">Booking: <span class="text-mono"><%= booking.reference %></span></p>

      <div class="payment-summary">
        <div class="payment-summary__row">
          <span>Unit</span>
          <span><%= booking.units ? booking.units.name : 'Storage Unit' %> (<%= booking.units ? booking.units.sqm + ' m\u00B2' : '' %>)</span>
        </div>
        <div class="payment-summary__row">
          <span>Duration</span>
          <span><%= booking.duration_months %> Month<%= booking.duration_months > 1 ? 's' : '' %></span>
        </div>
        <div class="payment-summary__row">
          <span>Amount Due</span>
          <span style="color:var(--clr-primary);font-family:var(--font-heading);">R <%= Number(booking.total_amount).toLocaleString('en-ZA') %></span>
        </div>
      </div>

      <div id="payment-error" class="payment-error-box" style="display:none;" role="alert"></div>

      <form id="paywall-form" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label form-label--required" for="cardNumber">Card Number</label>
          <div class="card-number-wrapper">
            <input type="text" id="cardNumber" name="cardNumber" class="form-input card-number-input" placeholder="1234 5678 9012 3456" maxlength="19" autocomplete="cc-number" inputmode="numeric" required>
            <span class="card-brand-icon" id="cardBrandIcon"></span>
          </div>
          <span class="form-error" id="cardNumberError"></span>
        </div>

        <div class="form-group">
          <label class="form-label form-label--required" for="cardName">Cardholder Name</label>
          <input type="text" id="cardName" name="cardName" class="form-input" placeholder="John Smith" autocomplete="cc-name" required>
          <span class="form-error" id="cardNameError"></span>
        </div>

        <div class="form-row-2">
          <div class="form-group">
            <label class="form-label form-label--required" for="cardExpiry">Expiry (MM/YY)</label>
            <input type="text" id="cardExpiry" name="cardExpiry" class="form-input" placeholder="MM/YY" maxlength="5" autocomplete="cc-exp" inputmode="numeric" required>
            <span class="form-error" id="cardExpiryError"></span>
          </div>
          <div class="form-group">
            <label class="form-label form-label--required" for="cardCvc">CVC</label>
            <input type="text" id="cardCvc" name="cardCvc" class="form-input" placeholder="123" maxlength="3" autocomplete="cc-csc" inputmode="numeric" required>
            <span class="form-error" id="cardCvcError"></span>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="billingAddress">Billing Address (optional)</label>
          <input type="text" id="billingAddress" name="billingAddress" class="form-input" placeholder="35 St Croix Street, Jeffreys Bay, 6330" autocomplete="billing street-address">
        </div>

        <div class="card-brand-row" aria-label="Accepted card types">
          <span class="card-brand-btn" id="visaBtn" style="display:flex;align-items:center;gap:6px;">
            <svg width="28" height="18" viewBox="0 0 28 18" fill="none"><rect width="28" height="18" rx="3" fill="#1A1F71"/><text x="14" y="12" font-family="Arial" font-size="9" font-weight="bold" fill="white" text-anchor="middle">VISA</text></svg>
          </span>
          <span class="card-brand-btn" id="mcBtn" style="display:flex;align-items:center;gap:6px;">
            <svg width="28" height="18" viewBox="0 0 28 18" fill="none"><rect width="28" height="18" rx="3" fill="#EB001B"/><circle cx="11" cy="9" r="6" fill="#EB001B"/><circle cx="17" cy="9" r="6" fill="#F79E1B"/><path d="M14 4.5a6 6 0 0 1 0 9 6 6 0 0 1 0-9z" fill="#FF5F00"/></svg>
          </span>
        </div>

        <button type="submit" class="btn btn--primary btn--lg btn--block" id="payBtn">
          Pay R <%= Number(booking.total_amount).toLocaleString('en-ZA') %>
        </button>

        <p class="text-center text-dim text-xs mt-4">
          <svg class="icon icon--sm icon--inline" aria-hidden="true"><use href="#icon-shield-check"/></svg>
          Demo mode &mdash; No real charges will be made
        </p>
      </form>
    </div>

    <div class="payment-card payment-success" id="payment-success-container" style="display:none;">
      <div class="confetti-container" id="confetti"></div>
      <div class="payment-success__icon"><svg class="icon icon--xxxl icon--success" aria-hidden="true"><use href="#icon-check-circle"/></svg></div>
      <h2 class="payment-success__title">Payment Successful!</h2>
      <p class="text-muted mb-6">Your booking is confirmed. Reference: <span class="text-mono text-primary"><%= booking.reference %></span></p>
      <div style="margin-bottom:var(--space-6);">
        <p class="text-sm text-dim">Amount paid: <span class="text-primary font-heading">R <%= Number(booking.total_amount).toLocaleString('en-ZA') %></span></p>
        <p class="text-sm text-dim">Booking ID: <span class="text-mono"><%= booking.id %></span></p>
      </div>
      <a href="/bookings/<%= booking.id %>" class="btn btn--primary">View Booking Details</a>
      <a href="/account/bookings" class="btn btn--outline mt-3">My Rentals</a>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-state__icon"><svg class="icon icon--xxxl icon--muted" aria-hidden="true"><use href="#icon-x-circle"/></svg></div>
      <h3 class="empty-state__title">Booking Not Found</h3>
      <p class="empty-state__text">This booking doesn't exist or has been removed.</p>
      <a href="/account/bookings" class="btn btn--primary">My Rentals</a>
    </div>
    <% } %>
  </div>
</section>

<script type="module">
(function() {
  const cardNumberInput = document.getElementById('cardNumber');
  const cardNameInput = document.getElementById('cardName');
  const cardExpiryInput = document.getElementById('cardExpiry');
  const cardCvcInput = document.getElementById('cardCvc');
  const cardBrandIcon = document.getElementById('cardBrandIcon');
  const visaBtn = document.getElementById('visaBtn');
  const mcBtn = document.getElementById('mcBtn');
  const payBtn = document.getElementById('payBtn');
  const paywallForm = document.getElementById('paywall-form');
  const paymentFormContainer = document.getElementById('payment-form-container');
  const paymentSuccessContainer = document.getElementById('payment-success-container');
  const paymentError = document.getElementById('payment-error');

  function detectCardBrand(number) {
    const cleaned = number.replace(/\s/g, '');
    if (/^4/.test(cleaned)) return 'visa';
    if (/^5[1-5]/.test(cleaned) || /^2[2-7]/.test(cleaned)) return 'mastercard';
    return null;
  }

  function updateBrandDisplay(brand) {
    if (brand === 'visa') {
      cardBrandIcon.innerHTML = '<svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#1A1F71"/><text x="24" y="20" font-family="Arial" font-size="12" font-weight="bold" fill="white" text-anchor="middle">VISA</text></svg>';
      visaBtn.classList.add('active');
      mcBtn.classList.remove('active');
    } else if (brand === 'mastercard') {
      cardBrandIcon.innerHTML = '<svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#1A1F71"/><circle cx="18" cy="15" r="9" fill="#EB001B" opacity="0.9"/><circle cx="30" cy="15" r="9" fill="#F79E1B" opacity="0.9"/><path d="M24 9a8.5 8.5 0 0 0 0 12 8.5 8.5 0 0 0 0-12z" fill="#FF5F00"/></svg>';
      mcBtn.classList.add('active');
      visaBtn.classList.remove('active');
    } else {
      cardBrandIcon.innerHTML = '';
      visaBtn.classList.remove('active');
      mcBtn.classList.remove('active');
    }
  }

  function luhnCheck(num) {
    const arr = (num + '').split('').reverse().map(x => parseInt(x));
    const sum = arr.reduce((acc, val, i) => {
      if (i % 2 !== 0) {
        val *= 2;
        if (val > 9) val -= 9;
      }
      return acc + val;
    }, 0);
    return sum % 10 === 0;
  }

  function formatCardNumber(value) {
    const cleaned = value.replace(/\D/g, '');
    const chunks = cleaned.match(/.{1,4}/g) || [];
    return chunks.join(' ').substring(0, 19);
  }

  function formatExpiry(value) {
    const cleaned = value.replace(/\D/g, '');
    if (cleaned.length >= 2) {
      return cleaned.substring(0, 2) + '/' + cleaned.substring(2, 4);
    }
    return cleaned;
  }

  cardNumberInput.addEventListener('input', (e) => {
    const formatted = formatCardNumber(e.target.value);
    e.target.value = formatted;
    const brand = detectCardBrand(formatted);
    updateBrandDisplay(brand);
    document.getElementById('cardNumberError').textContent = '';
  });

  cardExpiryInput.addEventListener('input', (e) => {
    e.target.value = formatExpiry(e.target.value);
    document.getElementById('cardExpiryError').textContent = '';
  });

  cardCvcInput.addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/\D/g, '').substring(0, 3);
    document.getElementById('cardCvcError').textContent = '';
  });

  cardNameInput.addEventListener('input', () => {
    document.getElementById('cardNameError').textContent = '';
  });

  function showError(msg) {
    paymentError.textContent = msg;
    paymentError.style.display = 'block';
  }

  function hideError() {
    paymentError.style.display = 'none';
  }

  function createConfetti() {
    const container = document.getElementById('confetti');
    const colors = ['#D4006A', '#1A1F71', '#EB001B', '#F79E1B', '#10B981', '#3B82F6'];
    for (let i = 0; i < 60; i++) {
      const piece = document.createElement('div');
      piece.className = 'confetti-piece';
      piece.style.left = Math.random() * 100 + '%';
      piece.style.background = colors[Math.floor(Math.random() * colors.length)];
      piece.style.animationDuration = (Math.random() * 2 + 2) + 's';
      piece.style.animationDelay = (Math.random() * 1) + 's';
      piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      container.appendChild(piece);
    }
    setTimeout(() => { container.innerHTML = ''; }, 5000);
  }

  paywallForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const cardNumber = cardNumberInput.value.replace(/\s/g, '');
    const cardName = cardNameInput.value.trim();
    const expiry = cardExpiryInput.value;
    const cvc = cardCvcInput.value;

    let hasError = false;

    if (!cardNumber || cardNumber.length < 13) {
      document.getElementById('cardNumberError').textContent = 'Please enter a valid card number';
      hasError = true;
    } else if (!luhnCheck(cardNumber)) {
      document.getElementById('cardNumberError').textContent = 'Invalid card number';
      hasError = true;
    } else {
      const brand = detectCardBrand(cardNumber);
      if (!brand) {
        document.getElementById('cardNumberError').textContent = 'We only accept Visa and Mastercard';
        hasError = true;
      }
    }

    if (!cardName || cardName.length < 2) {
      document.getElementById('cardNameError').textContent = 'Please enter the cardholder name';
      hasError = true;
    }

    const expiryParts = expiry.split('/');
    if (expiry.length !== 5 || expiryParts.length !== 2) {
      document.getElementById('cardExpiryError').textContent = 'Enter expiry as MM/YY';
      hasError = true;
    } else {
      const month = parseInt(expiryParts[0]);
      const year = parseInt('20' + expiryParts[1]);
      const now = new Date();
      const expDate = new Date(year, month - 1);
      if (month < 1 || month > 12 || expDate < now) {
        document.getElementById('cardExpiryError').textContent = 'Card has expired';
        hasError = true;
      }
    }

    if (!cvc || cvc.length !== 3) {
      document.getElementById('cardCvcError').textContent = 'CVC must be 3 digits';
      hasError = true;
    }

    if (hasError) return;

    payBtn.disabled = true;
    payBtn.innerHTML = '<span class="spinner"></span> Processing...';

   await new Promise(r => setTimeout(r, 2500));

     const success = Math.random() < 0.85;

     if (success) {
       try {
         const csrfToken = document.querySelector('[name="_csrf"]')?.value || '';
         const response = await fetch('/payments/process', {
           method: 'POST',
           headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
           body: JSON.stringify({
             bookingId: '<%= typeof booking !== "undefined" && booking ? booking.id : "" %>',
             cardLastFour: cardNumber.slice(-4),
             cardBrand: detectCardBrand(cardNumber),
             amount: '<%= typeof booking !== "undefined" && booking ? booking.total_amount : 0 %>',
           }),
         });
       } catch (err) {
         console.error('Payment processing error:', err);
       }

      paymentFormContainer.style.display = 'none';
      paymentSuccessContainer.style.display = 'block';
      createConfetti();
    } else {
      const errors = [
        'Card declined: insufficient funds',
        'Do not honor',
        'Card declined: call your bank',
        'Transaction timeout',
      ];
      showError(errors[Math.floor(Math.random() * errors.length)]);
      payBtn.disabled = false;
      payBtn.textContent = 'Pay R <%= typeof booking !== "undefined" && booking ? Number(booking.total_amount).toLocaleString("en-ZA") : "0" %>';
    }
  });
})();
</script>