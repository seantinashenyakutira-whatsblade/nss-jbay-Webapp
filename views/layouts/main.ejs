<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | National Secure Storage</title>
  <meta name="description" content="<%= description || 'Premium self-storage in Jeffrey\'s Bay' %>">
  <meta property="og:title" content="<%= title %> | National Secure Storage">
  <meta property="og:description" content="<%= description || 'Secure, affordable self-storage in Jeffrey\'s Bay. 24/7 CCTV, flexible contracts, drive-up access.' %>">
  <meta property="og:image" content="/assets/images/og-image.svg">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="theme-color" content="#D4006A">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="NSS JBay">
  <link rel="manifest" href="/manifest.json">
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=DM+Mono&display=swap" rel="stylesheet">
  <!-- Styles -->
  <link rel="stylesheet" href="/styles/variables.css">
  <link rel="stylesheet" href="/styles/reset.css">
  <link rel="stylesheet" href="/styles/typography.css">
  <link rel="stylesheet" href="/styles/layout.css">
  <link rel="stylesheet" href="/styles/animations.css">
  <link rel="stylesheet" href="/styles/icons.css">
  <link rel="stylesheet" href="/styles/components/navbar.css">
  <link rel="stylesheet" href="/styles/components/footer.css">
  <link rel="stylesheet" href="/styles/components/buttons.css">
  <link rel="stylesheet" href="/styles/components/forms.css">
  <link rel="stylesheet" href="/styles/components/cards.css">
  <link rel="stylesheet" href="/styles/components/modal.css">
  <link rel="stylesheet" href="/styles/components/toasts.css">
  <link rel="stylesheet" href="/styles/components/badges.css">
  <link rel="stylesheet" href="/styles/components/tables.css">
  <link rel="stylesheet" href="/styles/pages/global.css">
  <% if (title === 'Terms of Use' || title === 'Privacy Policy' || title === 'Refund & Cancellation Policy') { %>
  <link rel="stylesheet" href="/styles/pages/legal.css">
  <% } %>
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="apple-touch-icon" href="/assets/images/favicon.svg">
  <%- extraStyles || '' %>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  
  <%- include('../partials/navbar') %>
  
  <main id="main-content">
    <% if (messages && messages.length) { %>
      <div class="flash-messages">
        <% messages.forEach(msg => { %>
          <div class="toast toast--<%= msg.type %>" role="alert">
            <span><%= msg.text %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
    
    <%- body %>
  </main>
  
  <%- include('../partials/footer') %>
  
  <div id="toast-container" aria-live="polite"></div>
  <div id="modal-root"></div>
  
  <!-- Core JS -->
  <script type="module" src="/js/utils.js"></script>
  <script type="module" src="/js/components/navbar.js"></script>
  <script type="module" src="/js/components/footer.js"></script>
  <script type="module" src="/js/components/modal.js"></script>
  <script type="module" src="/js/components/toast.js"></script>
  <script type="module" src="/js/components/booking.js"></script>
  <script type="module" src="/js/main.js"></script>
  <script type="module" src="/js/images.js"></script>
  <%- include('../partials/icons-sprite') %>
  <script type="module" src="/js/auth.js"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <%- extraScripts || '' %>
</body>
</html>
