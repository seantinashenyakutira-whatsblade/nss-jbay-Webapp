# NSS JBay - Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Session secret - generate a random string for production
SESSION_SECRET=your-random-secret-here

# Supabase Project
# Get these from your Supabase project dashboard: Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# App
BASE_URL=http://localhost:3000
CURRENCY=R

# Site Info
SITE_NAME=National Secure Storage
SITE_LOCATION=Jeffrey's Bay
SITE_ADDRESS=35 St Croix Street, Jeffrey's Bay, Eastern Cape, 6330
SITE_PHONE_1=063 546 1740
SITE_PHONE_2=061 905 8382
SITE_EMAIL=info@nss-jbay.co.za

# Social
FB_URL=https://www.facebook.com/National.Secure.Storage.Bloemfontein

# === SETUP INSTRUCTIONS ===
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Project Settings > API and copy your URL and keys
# 3. Run the SQL in config/database.sql in Supabase SQL Editor
# 4. Update SUPABASE_URL with your project URL
# 5. Update SUPABASE_ANON_KEY with your anon/public key
# 6. Update SUPABASE_SERVICE_KEY with your service_role key (keep secret!)
# 7. For production: change SESSION_SECRET to a cryptographically random string
# 8. For production: update BASE_URL to your deployed domain
